# Copy this file to .env and fill in real values. Never commit the real .env.

# Secret key used to sign JWTs. MUST be a long, random string in production.
# e.g. generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string

# JWT signing algorithm.
ALGORITHM=HS256

# Access token lifetime, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SQLAlchemy async database URL. Default uses local SQLite via aiosqlite.
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Credentials for the single admin account, seeded automatically on startup
# if no user with this email exists yet. Change the password before any
# real deployment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-too

# Comma-separated list of allowed CORS origins, e.g. https://app.example.com,https://admin.example.com
# Empty by default (closed) since this API has no browser frontend yet.
CORS_ORIGINS=

# development | production. In production, SECRET_KEY must not be empty or a placeholder.
ENVIRONMENT=development

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
